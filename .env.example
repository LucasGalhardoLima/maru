# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Create an audience at resend.com/audiences (optional but recommended for managing your list)
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# "From" address — must be a verified domain in Resend
# During dev you can use: Maru <onboarding@resend.dev>  (Resend's shared domain, sends only to your own account)
RESEND_FROM=Maru <onboarding@resend.dev>

# Where YOU get notified of every new signup (optional)
NOTIFY_EMAIL=lima.galhardo@gmail.com
