---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Maru — a friend who reminds you to take your meds &amp; vitamins</title>
  <meta name="description" content="Maru is a gentle iPhone reminder for your medicines and vitamins. On-time local notifications, a happy little friend, and a streak that celebrates every dose. No login, no cloud — join the waitlist." />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Maru — a friend who looks after you" />
  <meta property="og:description" content="A gentle iPhone reminder for your meds & vitamins. No login, no cloud. Join the waitlist." />
  <meta property="og:site_name" content="Maru" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Maru — a friend who looks after you" />
  <meta name="twitter:description" content="A gentle iPhone reminder for your meds & vitamins. No login, no cloud. Join the waitlist." />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='23' fill='%23ec7e54'/%3E%3Cellipse cx='40' cy='50' rx='4' ry='6.5' fill='%232a211c'/%3E%3Cellipse cx='60' cy='50' rx='4' ry='6.5' fill='%232a211c'/%3E%3Cellipse cx='27' cy='68' rx='9.5' ry='6' fill='%23f7ab8c' opacity='.85'/%3E%3Cellipse cx='73' cy='68' rx='9.5' ry='6' fill='%23f7ab8c' opacity='.85'/%3E%3Cpath d='M38 66 Q50 78 62 66' stroke='%232a211c' stroke-width='2.5' fill='none' stroke-linecap='round'/%3E%3C/svg%3E" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=Baloo+2:wght@500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ===== NAV ===== -->
<header id="nav">
  <div class="container nav-inner">
    <div class="logo-lockup">
      <div class="maru-icon-sm" aria-hidden="true"><div class="maru-icon-inner"><div class="maru-icon-cheek maru-icon-cheek--l"></div><div class="maru-icon-cheek maru-icon-cheek--r"></div><div class="maru-icon-eye maru-icon-eye--l"></div><div class="maru-icon-eye maru-icon-eye--r"></div><div class="maru-icon-smile"></div></div></div>
      <span class="logo-text">maru</span>
    </div>
    <div class="nav-right">
      <div class="lang-switcher" role="group" aria-label="Language">
        <button class="lang-btn" data-lang="pt">PT</button>
        <button class="lang-btn lang-btn--active" data-lang="en">EN</button>
      </div>
      <a href="#waitlist" class="btn-primary btn-sm" data-t="navCta">Join the list</a>
    </div>
  </div>
</header>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-deco hero-deco--1" aria-hidden="true"></div>
  <div class="hero-deco hero-deco--2" aria-hidden="true"></div>
  <div class="hero-deco hero-deco--3" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <div class="eyebrow">
        <span class="eyebrow-check" aria-hidden="true">✓</span>
        <span data-t="heroEyebrow">Medicine &amp; vitamin reminder</span>
      </div>
      <h1 class="hero-h1" data-t="heroTitle">A friend who looks after you.</h1>
      <p class="hero-benefit" data-t="heroBenefit">Never miss a dose again.</p>
      <p class="hero-sub" data-t="heroSub">
        Maru reminds you about your meds and vitamins right on time — and cheers you on when you take them. No login, no cloud, all on your iPhone.
      </p>

      <div id="waitlist" class="waitlist-box">
        <form id="form-hero" class="waitlist-form" novalidate>
          <input id="email-hero" type="email" class="email-input" autocomplete="email"
            data-t-placeholder="formPlaceholder" placeholder="you@email.com" required />
          <button type="submit" class="btn-primary btn-form" id="submit-hero" data-t="formButton">I want Maru</button>
        </form>
        <p class="form-hint" id="hint-hero" data-t="formHint">No spam. Just a ping when Maru lands.</p>
        <div class="success-card" id="success-hero" hidden>
          <div class="success-check" aria-hidden="true">✓</div>
          <div>
            <div class="success-title" data-t="successTitle">You're on the list!</div>
            <div class="success-body" data-t="successBody">You're among the first — we'll ping you the moment Maru lands.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-art" aria-hidden="true">
      <div class="float-dot float-dot--check float-dot--1"><span>✓</span></div>
      <div class="float-dot float-dot--check float-dot--2"><span>✓</span></div>
      <div class="float-dot float-dot--plain float-dot--3"></div>
      <div class="maru-character maru-bob">
        <div class="maru-body">
          <div class="maru-cheek maru-cheek--l"></div>
          <div class="maru-cheek maru-cheek--r"></div>
          <div class="maru-eye maru-eye--l maru-blink"></div>
          <div class="maru-eye maru-eye--r maru-blink"></div>
          <div class="maru-smile"></div>
          <div class="maru-badge maru-pop maru-celebrate">✓</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== THE FEELING ===== -->
<section class="section section--white">
  <div class="container" data-reveal>
    <div class="section-header">
      <div class="kicker"><span class="kicker-num">01</span>&nbsp;&nbsp;<span data-t="feelKicker">The feeling</span></div>
      <h2 class="section-h2" data-t="feelTitle">Taking your meds shouldn't feel like a memory test.</h2>
    </div>
    <div class="worry-grid">
      <div class="worry-card">
        <div class="worry-quote" aria-hidden="true">"</div>
        <p class="worry-text" data-t="worry1">Did I already take it this morning?</p>
      </div>
      <div class="worry-card">
        <div class="worry-quote" aria-hidden="true">"</div>
        <p class="worry-text" data-t="worry2">Was that today… or yesterday?</p>
      </div>
    </div>
    <div class="feel-resolve">
      <div class="maru-icon-md" aria-hidden="true"><div class="maru-icon-inner maru-icon-inner--md"><div class="maru-icon-cheek maru-icon-cheek--l"></div><div class="maru-icon-cheek maru-icon-cheek--r"></div><div class="maru-icon-eye maru-icon-eye--l"></div><div class="maru-icon-eye maru-icon-eye--r"></div><div class="maru-icon-smile"></div></div></div>
      <p class="feel-resolve-text" data-t="feelResolve">Maru remembers, so you don't have to.</p>
      <div class="principle-badge">
        <span class="principle-dot" aria-hidden="true"></span>
        <span data-t="principle">Maru reminds. Maru never nags.</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== THE LOOP ===== -->
<section class="section section--white section--border-top">
  <div class="container" data-reveal>
    <div class="section-header">
      <div class="kicker"><span class="kicker-num">02</span>&nbsp;&nbsp;<span data-t="loopKicker">The loop</span></div>
      <h2 class="section-h2" data-t="loopTitle">Four steps. That's it.</h2>
    </div>
    <div class="loop-grid">
      <div class="loop-card loop-card--tilt-l">
        <div class="step-num">1</div>
        <div class="step-title" data-t="s1Title">Add it</div>
        <p class="step-body" data-t="s1Body">Name, dose, times and days. In seconds, no tutorial.</p>
      </div>
      <div class="loop-card loop-card--tilt-r">
        <div class="step-num">2</div>
        <div class="step-title" data-t="s2Title">Maru reminds you</div>
        <p class="step-body" data-t="s2Body">A local notification right on time — works offline, no server.</p>
      </div>
      <div class="loop-card loop-card--tilt-l">
        <div class="step-num">3</div>
        <div class="step-title" data-t="s3Title">Taken or Skipped</div>
        <p class="step-body" data-t="s3Body">Mark it straight from the notification, without opening the app.</p>
      </div>
      <div class="loop-card loop-card--accent loop-card--tilt-r">
        <div class="step-num step-num--accent">✓</div>
        <div class="step-title step-title--accent" data-t="s4Title">Streak</div>
        <p class="step-body step-body--accent" data-t="s4Body">Each dose becomes a ✓ and your streak grows. Maru celebrates.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== MEET MARU (dark) ===== -->
<section class="section section--dark">
  <div class="meet-deco meet-deco--1" aria-hidden="true"></div>
  <div class="meet-deco meet-deco--2" aria-hidden="true"></div>
  <div class="container meet-grid" data-reveal>
    <div class="meet-art" aria-hidden="true">
      <div class="maru-character maru-character--lg maru-bob">
        <div class="maru-body maru-body--lg">
          <div class="maru-cheek maru-cheek--l maru-cheek--lg"></div>
          <div class="maru-cheek maru-cheek--r maru-cheek--lg"></div>
          <div class="maru-eye maru-eye--l maru-eye--lg maru-blink"></div>
          <div class="maru-eye maru-eye--r maru-eye--lg maru-blink"></div>
          <div class="maru-smile maru-smile--lg"></div>
        </div>
      </div>
    </div>
    <div class="meet-copy">
      <div class="kicker kicker--dark"><span class="kicker-num kicker-num--dark">03</span>&nbsp;&nbsp;<span data-t="meetKicker">Hi, I'm Maru</span></div>
      <h2 class="section-h2 section-h2--dark" data-t="meetTitle">The round little friend who won't let you forget.</h2>
      <p class="meet-body" data-t="meetBody">I'm a friendly circle who lives in your pocket. My job? Remind you kindly and celebrate every dose you take.</p>
      <ul class="meet-list">
        <li class="meet-item"><span class="meet-check" aria-hidden="true">✓</span><span data-t="meet1">I nudge you on time — never before coffee.</span></li>
        <li class="meet-item"><span class="meet-check" aria-hidden="true">✓</span><span data-t="meet2">I live only on your iPhone. Your data is yours.</span></li>
        <li class="meet-item"><span class="meet-check" aria-hidden="true">✓</span><span data-t="meet3">Skipped one? No judgment. We'll try again tomorrow.</span></li>
      </ul>
    </div>
  </div>
</section>

<!-- ===== STREAK BAND ===== -->
<section class="section section--cream">
  <div class="container streak-center" data-reveal>
    <div class="kicker"><span class="kicker-num">04</span>&nbsp;&nbsp;<span data-t="streakKicker">Streak</span></div>
    <h2 class="section-h2 streak-h2" data-t="streakTitle">It's not about remembering. It's about caring for yourself.</h2>
    <p class="streak-body" data-t="streakBody">Each dose becomes a ✓. The days become a streak. And Maru is happy right along with you.</p>
    <div class="streak-dots" aria-hidden="true">
      <div class="streak-dot streak-dot--done">✓</div>
      <div class="streak-dot streak-dot--done">✓</div>
      <div class="streak-dot streak-dot--done">✓</div>
      <div class="streak-dot streak-dot--done">✓</div>
      <div class="streak-dot streak-dot--done">✓</div>
      <div class="streak-dot streak-dot--done">✓</div>
      <div class="streak-dot streak-dot--next" id="streak-next"><span id="streak-ck">✓</span></div>
      <div class="streak-chip" id="streak-chip" data-t="streakCount">12-day streak</div>
    </div>
  </div>
</section>

<!-- ===== VALUES ===== -->
<section class="section section--white">
  <div class="container values-grid" data-stagger>
    <div class="value-card">
      <div class="value-icon" aria-hidden="true">丸</div>
      <h3 class="value-title" data-t="v1Title">Local &amp; private</h3>
      <p class="value-body" data-t="v1Body">No account, no backend. Your data never leaves your iPhone.</p>
    </div>
    <div class="value-card">
      <div class="value-icon" aria-hidden="true">0</div>
      <h3 class="value-title" data-t="v2Title">Zero onboarding</h3>
      <p class="value-body" data-t="v2Body">Open it and go. No sign-up, no annoying tutorial.</p>
    </div>
    <div class="value-card">
      <div class="value-icon" aria-hidden="true">✓</div>
      <h3 class="value-title" data-t="v3Title">Reminders that work</h3>
      <p class="value-body" data-t="v3Body">Rolling re-scheduling so it never misses — even past iOS's limit.</p>
    </div>
  </div>
</section>

<!-- ===== FINAL CTA ===== -->
<section class="section section--cta">
  <div class="cta-deco cta-deco--1" aria-hidden="true"></div>
  <div class="cta-deco cta-deco--2" aria-hidden="true"></div>
  <div class="container cta-center" data-reveal>
    <div class="cta-maru maru-bob" aria-hidden="true">
      <div class="cta-maru-inner">✓</div>
    </div>
    <div class="kicker kicker--cta" data-t="closingEcho">Take it. Check it. Keep your streak.</div>
    <h2 class="cta-h2" data-t="footerTitle">Get on the Maru list.</h2>
    <p class="cta-sub" data-t="footerSub">Be one of the first to try it when the beta opens. Takes 5 seconds.</p>
    <div class="waitlist-box waitlist-box--cta">
      <form id="form-cta" class="waitlist-form" novalidate>
        <input id="email-cta" type="email" class="email-input email-input--dark" autocomplete="email"
          data-t-placeholder="formPlaceholder" placeholder="you@email.com" required />
        <button type="submit" class="btn-dark btn-form" id="submit-cta" data-t="formButton">I want Maru</button>
      </form>
      <p class="form-hint form-hint--cta" id="hint-cta" data-t="formHint">No spam. Just a ping when Maru lands.</p>
      <div class="success-card success-card--cta" id="success-cta" hidden>
        <div class="success-check" aria-hidden="true">✓</div>
        <div>
          <div class="success-title" data-t="successTitle">You're on the list!</div>
          <div class="success-body" data-t="successBody">You're among the first — we'll ping you the moment Maru lands.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== FOOTER ===== -->
<footer class="footer">
  <div class="container footer-inner">
    <div class="logo-lockup">
      <div class="maru-icon-sm maru-icon-sm--dark" aria-hidden="true"><div class="maru-icon-inner"><div class="maru-icon-cheek maru-icon-cheek--l"></div><div class="maru-icon-cheek maru-icon-cheek--r"></div><div class="maru-icon-eye maru-icon-eye--l"></div><div class="maru-icon-eye maru-icon-eye--r"></div><div class="maru-icon-smile"></div></div></div>
      <span class="logo-text logo-text--light">maru</span>
    </div>
    <div class="footer-links">
      <a href="#" class="footer-link" data-t="linkPrivacy">Privacy</a>
      <a href="#" class="footer-link" data-t="linkTerms">Terms</a>
      <span class="footer-copy" data-t="footerLegal">© 2026 maru · made with care</span>
    </div>
  </div>
  <div class="footer-disclaimer-bar">
    <div class="container footer-disclaimer">
      <span class="disclaimer-icon" aria-hidden="true">⚕</span>
      <p data-t="footerDisclaimer">
        Maru is a reminder tool and not a substitute for professional medical advice, diagnosis, or treatment. Always talk to your doctor or pharmacist about your medication.
      </p>
    </div>
  </div>
</footer>

</body>
</html>

<style is:global>
  [hidden] { display: none !important; }
  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: 'Hanken Grotesk', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    background: #fff;
    color: #2a211c;
    overflow-x: hidden;
  }

  .container { max-width: 1120px; margin: 0 auto; padding-inline: 28px; }
  .section { padding-block: 80px; }
  .section--white { background: #fff; }
  .section--white.section--border-top { border-top: 1px solid #f3e6da; }
  .section--cream { background: #fbf3ec; border-bottom: 1px solid #f3e6da; }
  .section--dark { background: #2a211c; position: relative; overflow: hidden; }
  .section--cta { background: #ec7e54; position: relative; overflow: hidden; }

  .section-h2 { margin: 14px 0 0; font: 800 42px/1.06 'Baloo 2', sans-serif; letter-spacing: -.01em; color: #2a211c; text-wrap: balance; }
  .section-h2--dark { color: #fff; }
  .kicker { font: 700 12px/1 'Hanken Grotesk', sans-serif; letter-spacing: .16em; text-transform: uppercase; color: #ec7e54; }
  .kicker-num { color: #e0b9a4; }
  .kicker--dark { color: #f2925f; }
  .kicker-num--dark { color: #9a7059; }
  .kicker--cta { color: #ffd9c6; font-size: 13px; letter-spacing: .16em; text-transform: uppercase; font-weight: 700; margin-bottom: 12px; }

  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }
  @keyframes pop { 0% { transform: scale(0) rotate(-12deg); } 60% { transform: scale(1.14) rotate(3deg); } 100% { transform: scale(1) rotate(0); } }
  @keyframes drift { 0%,100% { transform: translate(0,0); } 50% { transform: translate(5px,-9px); } }
  @keyframes blink { 0%,92%,100% { transform: scaleY(1); } 96% { transform: scaleY(.1); } }
  @keyframes celebrate { 0%,80%,100% { transform: scale(1) rotate(0); } 87% { transform: scale(1.16) rotate(6deg); } 93% { transform: scale(.95) rotate(-4deg); } }
  @keyframes riseIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }

  .maru-bob { animation: bob 3.6s ease-in-out infinite; }
  .maru-blink { animation: blink 6s ease-in-out infinite; }
  .maru-pop { animation: pop .6s ease-out both; }
  .maru-celebrate { animation: pop .6s ease-out, celebrate 6s 2s ease-in-out infinite; }

  [data-reveal] { will-change: opacity, transform; }
  body.has-reveal [data-reveal] { opacity: 0; transform: translateY(20px); transition: opacity .7s cubic-bezier(.16,.84,.44,1), transform .7s cubic-bezier(.16,.84,.44,1); }
  body.has-reveal [data-reveal].is-in { opacity: 1; transform: none; }
  body.has-reveal [data-stagger] > * { opacity: 0; }
  body.has-reveal [data-stagger].is-in > * { animation: riseIn .6s cubic-bezier(.16,.84,.44,1) both; animation-delay: var(--d, 0s); }

  @media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation: none !important; transition: none !important; } }

  a:focus-visible, button:focus-visible, input:focus-visible { outline: 3px solid #2a211c; outline-offset: 3px; border-radius: 8px; }

  /* Maru character */
  .maru-character { position: relative; width: 240px; height: 240px; }
  .maru-body { position: absolute; inset: 0; border-radius: 50%; background: #ec7e54; box-shadow: 0 28px 56px -14px rgba(236,126,84,.6), inset 0 -16px 34px rgba(200,90,51,.28); }
  .maru-cheek { position: absolute; border-radius: 50%; background: #f59e7e; opacity: .75; width: 34px; height: 20px; top: 138px; }
  .maru-cheek--l { left: 42px; }
  .maru-cheek--r { right: 42px; }
  .maru-eye { position: absolute; border-radius: 50%; background: #2a211c; width: 15px; height: 21px; top: 104px; }
  .maru-eye--l { left: 84px; }
  .maru-eye--r { right: 84px; }
  .maru-smile { position: absolute; left: 50%; top: 118px; transform: translateX(-50%); width: 56px; height: 56px; border-radius: 50%; border: 6px solid transparent; border-bottom-color: #2a211c; }
  .maru-badge { position: absolute; right: -4px; top: -4px; width: 62px; height: 62px; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(42,33,28,.2); color: #ec7e54; font: 800 30px/1 'Baloo 2', sans-serif; }

  .maru-character--lg { width: 260px; height: 260px; }
  .maru-body--lg { box-shadow: 0 30px 60px -12px rgba(236,126,84,.5), inset 0 -16px 36px rgba(200,90,51,.3); }
  .maru-cheek--lg { width: 36px; height: 22px; top: 150px; }
  .maru-cheek--l.maru-cheek--lg { left: 48px; }
  .maru-cheek--r.maru-cheek--lg { right: 48px; }
  .maru-eye--lg { width: 16px; height: 23px; top: 112px; }
  .maru-eye--l.maru-eye--lg { left: 92px; }
  .maru-eye--r.maru-eye--lg { right: 92px; }
  .maru-smile--lg { top: 128px; width: 60px; height: 60px; border-width: 6px; }

  /* Small icon in nav/footer — CSS-drawn face */
  /* Small icon (34px) */
  .maru-icon-sm {
    width: 34px; height: 34px; flex-shrink: 0;
    overflow: hidden; border-radius: 8px;
    box-shadow: 0 4px 10px rgba(236,126,84,.35);
  }
  .maru-icon-sm--dark { box-shadow: none; }

  /* Medium icon (64px) */
  .maru-icon-md {
    width: 64px; height: 64px; overflow: hidden;
    border-radius: 14px;
    box-shadow: 0 12px 24px -8px rgba(236,126,84,.5);
    margin-bottom: 20px;
  }

  /* Icon face — drawn at 180px then scaled down to fit container */
  .maru-icon-inner {
    position: relative; width: 180px; height: 180px; border-radius: 42px;
    background: #ec7e54;
    transform: scale(0.18889); transform-origin: top left;
  }
  .maru-icon-inner--md { transform: scale(0.35556); }

  .maru-icon-cheek {
    position: absolute; width: 34px; height: 20px; border-radius: 50%;
    background: #f7ab8c; opacity: .85; top: 112px;
  }
  .maru-icon-cheek--l { left: 32px; }
  .maru-icon-cheek--r { right: 32px; }
  .maru-icon-eye {
    position: absolute; width: 15px; height: 23px; border-radius: 50%;
    background: #2a211c; top: 78px;
  }
  .maru-icon-eye--l { left: 64px; }
  .maru-icon-eye--r { right: 64px; }
  .maru-icon-smile {
    position: absolute; left: 50%; top: 98px; transform: translateX(-50%);
    width: 42px; height: 42px; border-radius: 50%;
    border: 4.5px solid transparent; border-bottom-color: #2a211c;
  }

  /* NAV */
  #nav { position: sticky; top: 0; z-index: 30; background: rgba(251,243,236,.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid #f0e3d8; }
  .nav-inner { display: flex; align-items: center; gap: 16px; padding-block: 13px; }
