  let lang = 'en';
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function getLang() {
    try {
      const saved = localStorage.getItem('maru_lang');
      if (saved === 'pt' || saved === 'en') return saved;
      return (navigator.language || 'en').toLowerCase().startsWith('pt') ? 'pt' : 'en';
    } catch { return 'en'; }
  }

  function applyTranslations() {
    const t = STRINGS[lang];
    document.documentElement.lang = lang;
    document.querySelectorAll('[data-t]').forEach((el) => {
      const key = el.dataset.t;
      if (key && key in t) el.textContent = t[key];
    });
    document.querySelectorAll('[data-t-placeholder]').forEach((el) => {
      const key = el.dataset.tPlaceholder;
      if (key && key in t) el.placeholder = t[key];
    });
    document.querySelectorAll('.lang-btn').forEach((btn) => {
      btn.classList.toggle('lang-btn--active', btn.dataset.lang === lang);
    });
    // Sync button labels
    ['hero', 'cta'].forEach((s) => {
      const btn = document.getElementById('submit-' + s);
      if (btn && !btn.disabled) btn.textContent = t.formButton;
    });
  }

  function setLang(l) {
    lang = l;
    try { localStorage.setItem('maru_lang', l); } catch { }
    applyTranslations();
  }

  function setHint(suffix, text, isError) {
    const el = document.getElementById('hint-' + suffix);
    if (!el) return;
    el.textContent = text;
    el.classList.toggle('is-error', isError);
  }

  function setFormBusy(suffix, busy) {
    const btn = document.getElementById('submit-' + suffix);
    const inp = document.getElementById('email-' + suffix);
    if (btn) { btn.disabled = busy; btn.textContent = busy ? STRINGS[lang].formSubmitting : STRINGS[lang].formButton; }
    if (inp) inp.disabled = busy;
  }

  function markJoined() {
    ['hero', 'cta'].forEach((s) => {
      const box = document.getElementById('form-' + s)?.closest('.waitlist-box');
      if (!box) return;
      box.querySelector('.waitlist-form')?.setAttribute('hidden', '');
      box.querySelector('.form-hint')?.setAttribute('hidden', '');
      document.getElementById('success-' + s)?.removeAttribute('hidden');
    });
  }

  async function handleSubmit(e, suffix) {
    e.preventDefault();
    const inp = document.getElementById('email-' + suffix);
    const email = (inp?.value ?? '').trim();
    const t = STRINGS[lang];

    if (!EMAIL_RE.test(email)) {
      inp?.classList.add('is-error');
      setHint(suffix, t.errInvalid, true);
      inp?.focus();
      return;
    }

    // Duplicate check
    try {
      const prev = JSON.parse(localStorage.getItem('maru_emails') ?? '[]');
      if (prev.includes(email.toLowerCase())) { markJoined(); return; }
    } catch { }

    setFormBusy(suffix, true);
    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, lang }),
      });
      if (!res.ok) throw new Error('bad-status');

      try {
        const prev = JSON.parse(localStorage.getItem('maru_emails') ?? '[]');
        prev.push(email.toLowerCase());
        localStorage.setItem('maru_emails', JSON.stringify(prev));
        localStorage.setItem('maru_joined', '1');
      } catch { }

      markJoined();
    } catch {
      setFormBusy(suffix, false);
      setHint(suffix, t.errNetwork, true);
    }
  }

  function setupReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    requestAnimationFrame(() => {
      const els = document.querySelectorAll('[data-reveal],[data-stagger]');
      if (!els.length) return;
      document.body.classList.add('has-reveal');
      const stagger = (el) => {
        if (el.hasAttribute('data-stagger'))
          Array.from(el.children).forEach((c, i) => c.style.setProperty('--d', i * 0.09 + 's'));
      };
      const reveal = (el) => { stagger(el); el.classList.add('is-in'); };
      const safety = setTimeout(() => els.forEach(reveal), 2500);
      try {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((en) => { if (en.isIntersecting) { reveal(en.target); io.unobserve(en.target); } });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
        clearTimeout(safety);
      } catch { clearTimeout(safety); els.forEach(reveal); }
    });
  }

  function startStreakDemo() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const tick = () => {
      const dot = document.getElementById('streak-next');
      const chip = document.getElementById('streak-chip');
      dot?.classList.add('is-done');
      if (chip) { chip.classList.add('is-pop'); setTimeout(() => chip.classList.remove('is-pop'), 340); }
      setTimeout(() => dot?.classList.remove('is-done'), 1600);
    };
    setInterval(tick, 4800);
    setTimeout(tick, 1400);
  }

  document.addEventListener('DOMContentLoaded', () => {
    lang = getLang();
    applyTranslations();

    document.querySelectorAll('.lang-btn').forEach((btn) =>
      btn.addEventListener('click', () => setLang(btn.dataset.lang))
    );

    ['hero', 'cta'].forEach((s) => {
      document.getElementById('form-' + s)?.addEventListener('submit', (e) => handleSubmit(e, s));
      document.getElementById('email-' + s)?.addEventListener('input', () => {
        document.getElementById('email-' + s)?.classList.remove('is-error');
        setHint(s, STRINGS[lang].formHint, false);
      });
    });

    setupReveal();
    startStreakDemo();
  });
</script>
